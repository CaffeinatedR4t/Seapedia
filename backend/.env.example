# Supabase (PostgreSQL) — Primary database
# Get this from: Supabase Dashboard → Project Settings → Database → Connection String → URI
# Use "Transaction" mode (port 5432) for the Go backend
DATABASE_URL=postgres://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# Individual vars (fallback if DATABASE_URL is not set)
DB_HOST=db.[YOUR-PROJECT-REF].supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=[YOUR-PASSWORD]
DB_NAME=postgres
DB_SSLMODE=require

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Server
GIN_MODE=debug
PORT=8080
